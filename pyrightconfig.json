{
  "typeCheckingMode": "standard",
  "reportMissingImports": "warning",
  "include": [
    "data",
    "model/picks_log.py",
    "services/scheduler_services.py",
    "services/settlement_service.py",
    "services/alert_service.py",
    "services/dispatch_service.py"
  ],
  "exclude": [
    "**/__pycache__",
    ".planning/**",
    "logs/**",
    "tests/**"
  ],
  "ignore": [
    "scheduler.py",
    "main.py",
    "bot/telegram_bot.py",
    "model/analisar_jogo.py"
  ],
  "executionEnvironments": [
    {
      "root": "data",
      "extraPaths": [
        ".",
        "model",
        "services"
      ]
    },
    {
      "root": "services",
      "extraPaths": [
        ".",
        "data",
        "model"
      ]
    },
    {
      "root": "model",
      "extraPaths": [
        "data",
        "services",
        "."
      ]
    }
  ],
  "reportMissingModuleSource": "warning"
}

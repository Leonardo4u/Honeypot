# Required credentials
BOT_TOKEN= # str, default: empty, Telegram bot token
CANAL_VIP= # str, default: empty, VIP channel/chat id
CANAL_FREE= # str, default: empty, FREE channel/chat id
ODDS_API_KEY= # str, default: empty, The Odds API key
API_FOOTBALL_KEY= # str, default: empty, API-Football key

# Data and runtime paths
BOT_DATA_DIR=./data # path, default: ./data, base directory for runtime data files
EDGE_PLAYBOOK_URL=docs/runbooks/emergency.md # str, default: docs/runbooks/emergency.md, incident playbook link

# Output and terminal UX
EDGE_LOG_LEVEL=normal # enum(normal|debug), default: normal, scheduler log verbosity
EDGE_MINIMAL_OUTPUT=1 # bool(0/1), default: 1, compact runtime console output
EDGE_SHOW_STARTUP_BANNER=1 # bool(0/1), default: 1, show startup banner
EDGE_FORCE_ANSI_COLOR=0 # bool(0/1), default: 0, force ANSI color in terminal
EDGE_IDLE_ASCII_ANIM=0 # bool(0/1), default: 0, enable idle ASCII animation
EDGE_IDLE_ASCII_FRAME_MS=120 # int, default: 120, frame delay for idle animation
EDGE_IDLE_ASCII_MAX_W=52 # int, default: 52, max width for idle ASCII animation
EDGE_IDLE_ASCII_MAX_H=18 # int, default: 18, max height for idle ASCII animation
EDGE_RESULTS_CHECK_INTERVAL_MIN=30 # int, default: 30, minutes between result verification runs in the 17h-23h window (minimum 5)

# Operational metadata
EDGE_OPERATOR=system # str, default: system, operator id used in audit trails
EDGE_VERSION=dev # str, default: dev, runtime version tag persisted in signals

# Guardrails and canary controls
EDGE_KILL_SWITCH=0 # bool(0/1), default: 0, emergency stop for sending new signals
EDGE_MAX_SINAIS_DIA=10 # int, default: 10, max number of daily signals
EDGE_MAX_DAILY_LOSS_UNITS=8.0 # float, default: 8.0, daily loss circuit breaker
EDGE_MAX_EXPOSURE_WINDOW_UNITS=12.0 # float, default: 12.0, exposure cap in rolling window
EDGE_EXPOSURE_WINDOW_HOURS=6 # int, default: 6, rolling exposure window size in hours
EDGE_PROVIDER_ERROR_RATE_MAX=0.55 # float, default: 0.55, max tolerated provider error rate
EDGE_CANARY_ENABLED=0 # bool(0/1), default: 0, enable canary mode
EDGE_CANARY_RATIO=1.0 # float, default: 1.0, accepted share of signals under canary

# Advanced model flags
EDGE_ADVANCED_PIPELINE_ENABLED=0 # bool(0/1), default: 0, enable advanced integrated pipeline
EDGE_ADVANCED_PIPELINE_MC_SIMS=2000 # int, default: 2000, Monte Carlo simulations in advanced pipeline
EDGE_POLICY_V2_ENABLED=0 # bool(0/1), default: 0, enable policy v2 gate
EDGE_POLICY_V2_SHADOW=1 # bool(0/1), default: 1, run policy v2 in shadow mode only

# SLO thresholds
SLO_CYCLE_AVAILABILITY_MIN=0.95 # float, default: 0.95, minimum healthy cycle availability
SLO_FALLBACK_RATE_MAX=0.35 # float, default: 0.35, max fallback rate tolerated
SLO_CYCLE_LATENCY_MAX_SECONDS=120 # float, default: 120, max cycle latency in seconds
SLO_DRIFT_MAX_BRIER=0.25 # float, default: 0.25, max drift Brier threshold

# Backtest/promotion thresholds (scripts)
EDGE_BACKTEST_WINDOW_DAYS=28 # int, default: 28, moving-window backtest horizon
EDGE_BACKTEST_MIN_SIGNALS=30 # int, default: 30, minimum sample to evaluate promotion
EDGE_PROMOTION_MIN_ROI_PCT=0.5 # float, default: 0.5, minimum ROI for promotion gate
EDGE_PROMOTION_MIN_WIN_RATE=0.5 # float, default: 0.5, minimum win rate for promotion gate
EDGE_PROMOTION_MAX_BRIER=0.25 # float, default: 0.25, maximum Brier for promotion gate
EDGE_PROMOTION_MIN_CLV=0.0 # float, default: 0.0, minimum CLV for promotion gate
